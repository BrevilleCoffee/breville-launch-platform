function deleteProject(id) {
  const p = getProject(id);
  if (!p) return;
  const name = p.name === 'TBD' ? p.model : `${p.model} — ${p.name}`;
  if (!confirm(`Delete "${name}"?\n\nThis permanently removes the project and all its data. This cannot be undone.\n\nTip: Export a JSON backup first if you want to keep it.`)) return;
  // Save a version before deleting so it's recoverable
  saveVersion(`Before delete: ${name}`, 'auto');
  state.projects = state.projects.filter(x => x.id !== id);
  if (state.activeProjectId === id) {
    state.activeProjectId = state.projects[0]?.id || null;
  }
  state.activeView = state.activeProjectId ? 'tracker' : 'home';
  save();
  closeModal('editProjectModal');
  closeModal('archiveModal');
  renderAll();
  showView(state.activeView);
}

function archiveProject(id) {
  const p = getProject(id);
  if (!p) return;
  state.activeProjectId = id;
  state.activeView = 'exec';
  renderAll();
  showView('exec');
  closeModal('archiveModal');
  setTimeout(() => {
    window.print();
    setTimeout(() => {
      state.projects = state.projects.filter(x=>x.id!==id);
      state.archived.push({ ...p, archivedAt: Date.now() });
      if (state.activeProjectId === id) {
        state.activeProjectId = state.projects[0]?.id || null;
      }
      state.activeView = state.activeProjectId ? 'tracker' : 'home';
      save();
      renderAll();
      showView(state.activeView);
    }, 500);
  }, 300);
}

