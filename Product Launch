                  style="background:transparent;border:none;border-bottom:1px solid var(--bdr2);color:var(--ink3);font-size:10px;font-family:'DM Sans',sans-serif;outline:none;width:90px;"
                  value="${escHtml(r.launchDate)}" placeholder="TBD"
                  onchange="updateRetailerDate('${p.id}','${r.id}',this.value)"
                  onclick="event.stopPropagation()"></div>
              </div>
            </div>
            <div style="text-align:right">
              <div class="rcard-pct" style="color:${pctColor(pct)}">${pct}%</div>
              <div style="font-size:10px;color:var(--ink3)">${done}/${total} tasks</div>
            </div>
          </div>
          <div class="rcard-bar"><div class="rcard-bar-fill" style="width:${pct}%;background:${r.color}"></div></div>
          <div class="rcard-tasks">`;
      r.tasks.forEach((t, ti) => {
        html += `
          <div class="rtask" onclick="toggleRetailerTask('${p.id}','${r.id}',${ti})">
            <input type="checkbox" class="tchk" ${t.done?'checked':''} onclick="event.stopPropagation();toggleRetailerTask('${p.id}','${r.id}',${ti})">
            <span class="rtask-name ${t.done?'done':''}">${t.name}</span>
          </div>`;
      });

      // Links row
      const hasHomepage = r.homepageUrl && r.homepageUrl.length > 0;
      const hasBreville = r.brevilleUrl && r.brevilleUrl.length > 0;
      const hasPdp      = r.pdpUrl && r.pdpUrl.length > 0;
      html += `
        <div class="rcard-links">
          ${hasHomepage ? `<a class="rlink rlink-home" href="${r.homepageUrl}" target="_blank" rel="noopener">🏠 Site</a>` : ''}
          ${hasBreville ? `<a class="rlink rlink-brand" href="${r.brevilleUrl}" target="_blank" rel="noopener">⚡ Breville Page</a>` : ''}
          ${hasPdp
            ? `<a class="rlink rlink-pdp-live" href="${escHtml(r.pdpUrl)}" target="_blank" rel="noopener">🟢 PDP Live</a>`
            : `<span class="rlink rlink-pdp-pending">○ PDP Pending</span>`
          }
          <div class="pdp-input-wrap">
            <input class="pdp-url-input" type="url"
              value="${escHtml(r.pdpUrl||'')}"
              placeholder="Paste PDP URL when live…"
              onchange="updateRetailerPdp('${p.id}','${r.id}',this.value)"
              onclick="event.stopPropagation()">
          </div>
        </div>`;

      html += `</div></div>`;
    });
    html += `</div></div>`;
  });
  document.getElementById('retailerLayout').innerHTML = html;
}

function toggleRetailerTask(pId, rId, ti) {
  const p = getProject(pId);
  const r = p?.retailers.find(x=>x.id===rId);
  if(r) { r.tasks[ti].done = !r.tasks[ti].done; save(); renderRetailers(); }
}

function updateRetailerDate(pId, rId, val) {
  const p = getProject(pId);
  const r = p?.retailers.find(x=>x.id===rId);
  if(r) { r.launchDate = val; save(); }
}

function updateRetailerPdp(pId, rId, val) {
  const p = getProject(pId);
  const r = p?.retailers.find(x=>x.id===rId);
  if(r) {
    r.pdpUrl = val.trim();
    save();
    renderRetailers(); // re-render so PDP button state updates
  }
}

