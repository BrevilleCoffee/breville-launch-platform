function exportJSON() {
  const data = { version:1, exportedAt:new Date().toISOString(), state };
  const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `breville-launch-${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  URL.revokeObjectURL(a.href);
}

function importJSON(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if (!data.state || !Array.isArray(data.state.projects)) {
        alert("Invalid file — doesn't look like a Breville Launch Platform backup.");
        return;
      }
      if (!confirm(`Import ${data.state.projects.length} project(s)?\n\nYour current state will be saved as a version first.`)) return;
      saveVersion('Before import — '+formatVersionLabel(), 'auto');
      Object.assign(state, data.state);
      save();
      renderAll();
      showView(state.activeView||'home');
      closeModal('dataModal');
    } catch(err) { alert('Could not read file. Make sure it\'s a valid JSON backup.'); }
  };
  reader.readAsText(file);
  input.value = '';
}

