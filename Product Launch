        <div class="scard-row">
          <span class="scard-lbl">Ship Date</span>
          <input class="inline-input" style="font-size:11px;text-align:right;max-width:90px"
            value="${escHtml(s.shipDate)}" placeholder="TBD"
            onchange="updateSampleField('${p.id}',${i},'shipDate',this.value)">
        </div>
        <div class="scard-row"><span class="scard-lbl">Status</span>
