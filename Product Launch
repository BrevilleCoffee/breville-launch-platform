function toggleTask(projectId, taskId, checked) {
  const p = getProject(projectId);
  const t = p?.tasks.find(x=>x.id===taskId);
  if (t) { t.status = checked ? 'done' : 'blocked'; save(); renderAll(); }
}

// Cycle task status: blocked → progress → done → na → blocked
function cycleTaskStatus(projectId, taskId) {
  const p = getProject(projectId);
  const t = p?.tasks.find(x=>x.id===taskId);
  if (!t) return;
  const cycle = ['blocked','progress','done','na'];
  const idx = cycle.indexOf(t.status);
  t.status = cycle[(idx+1) % cycle.length];
  // sync checkbox
  save();
  renderTaskArea(p);
  renderRail();
  renderTopbar();
}

// Update owner or due inline
function updateTaskField(projectId, taskId, field, value) {
  const p = getProject(projectId);
  const t = p?.tasks.find(x=>x.id===taskId);
  if (!t) return;
  t[field] = value;
  save();
  // Only full re-render for fields that affect KPIs/rail
  if (field === 'status' || field === 'due') {
    renderTaskArea(p);
    renderRail();
    renderTopbar();
  }
}

// Stage gate: cycle dev → comm → gtm → live → post → dev
const STAGE_CYCLE = ['dev','comm','gtm','live','post'];
function cycleStage(projectId) {
  const p = getProject(projectId);
  if (!p) return;
  const idx = STAGE_CYCLE.indexOf(p.stage);
  p.stage = STAGE_CYCLE[(idx+1) % STAGE_CYCLE.length];
  save();
  renderRail();
  renderHome();
  // refresh topbar eyebrow if this is the active project
  if (state.activeProjectId === projectId) renderTopbar();
}

