          <div class="sic-row"><span class="sic-lbl">Launch Qty</span>
            <input class="num-input" type="number" value="${sd.launchQty||''}" placeholder="0"
              onchange="updateSalesFcst('${p.id}','launchQty',this.value)"
              style="background:var(--surf2);border:1px solid var(--bdr);border-radius:4px;padding:3px 6px">
          </div>
        </div>

        <div class="sales-info-card">
          <div class="sic-title">Scenario Comparison</div>
          <div class="sic-row"><span class="sic-lbl">Likely Y1</span><span class="sic-val" style="color:var(--grn)">${fmtN(sd.fcst12m_l)}</span></div>
          <div class="sic-row"><span class="sic-lbl">Home Run Y1</span><span class="sic-val" style="color:var(--blu)">${fmtN(sd.fcst12m_h)}</span></div>
          <div class="sic-row"><span class="sic-lbl">Upside</span>
            <span class="sic-val pos">${sd.fcst12m_l>0?'+'+Math.round(((sd.fcst12m_h-sd.fcst12m_l)/sd.fcst12m_l)*100)+'%':'—'}</span>
          </div>
          <div class="sic-row"><span class="sic-lbl">Rev · Likely</span>
            <span class="sic-val gold">${p.map>0&&sd.fcst12m_l>0?'$'+Math.round(p.map*sd.fcst12m_l/1000)+'K':'—'}</span>
          </div>
          <div class="sic-row"><span class="sic-lbl">Rev · Home Run</span>
            <span class="sic-val" style="color:var(--blu)">${p.map>0&&sd.fcst12m_h>0?'$'+Math.round(p.map*sd.fcst12m_h/1000)+'K':'—'}</span>
          </div>
          <div class="sic-row"><span class="sic-lbl">POs Confirmed</span>
            <span class="sic-val" style="color:var(--org)">${fmtN(totalPoAll)}</span>
          </div>
        </div>

        <div class="sales-info-card">
          <div class="sic-title">Context & Notes</div>
          <textarea class="sales-notes-area" placeholder="Strategy notes, competitive context, seasonal assumptions..."
            onchange="updateSalesNotes('${p.id}',this.value)">${escHtml(sd.notes||'')}</textarea>
        </div>
      </div>
    </div>`;

  document.getElementById('salesLayout').innerHTML = html;
}

function setSalesScenario(pId, sc) {
  const p = getProject(pId);
  if (!p?.sales) return;
  p.sales.scenario = sc;
  save();
  renderSales();
}

function updateSalesRetailer(pId, idx, field, val) {
  const p = getProject(pId);
  if (!p?.sales) return;
  p.sales.retailers[idx][field] = parseInt(val)||0;
  save();
  renderSales();
}

function updateSalesRetailerDoors(pId, idx, val) {
  const p = getProject(pId);
  if (!p?.sales) return;
  const v = parseInt(val)||0;
  p.sales.retailers[idx].doors_l = v;
  p.sales.retailers[idx].doors_h = v; // doors don't change by scenario
  save();
}

function updateSalesRetailerPO(pId, idx, val) {
  const p = getProject(pId);
  if (!p?.sales) return;
  p.sales.retailers[idx].po = parseInt(val)||0;
  save();
  // update KPIs only — lightweight
  renderSales();
}

function updateSalesFcst(pId, field, val) {
  const p = getProject(pId);
  if (!p?.sales) return;
  p.sales[field] = parseInt(val)||0;
  save();
  renderSales();
}

function updateSalesNotes(pId, val) {
  const p = getProject(pId);
  if (p?.sales) { p.sales.notes = val; save(); }
}

// ═══════════════════════════════════════════
//  MARKETING CALENDAR — 3-MONTH VIEW
// ═══════════════════════════════════════════

let calStartMonth = new Date(); // first of the 3 months shown
calStartMonth = new Date(calStartMonth.getFullYear(), calStartMonth.getMonth(), 1);
let calSelectedDate = null;  // "YYYY-MM-DD" string
let calExpandedMonth = null; // {year, month} when a mini-month is expanded

const EV_DOT_COLOR = {
  product:'#5090ff', marketing:'#e8304a', sales:'#2ecc82',
  dtc:'#f07832', logistics:'#d4a843', cx:'#4dd9e0',
  launch:'#e8304a', retailer:'#8b5cf6', manual:'#4dd9e0',
};
const DEPT_EV_CLASS = {
  product:'ev-product', marketing:'ev-marketing', sales:'ev-sales',
  dtc:'ev-dtc', logistics:'ev-logistics', cx:'ev-cx',
  launch:'ev-launch', retailer:'ev-retailer', manual:'ev-manual',
};
const DAYS3 = ['S','M','T','W','T','F','S'];
const DAYS7 = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

function getCalEvents(p) {
  const events = [];
  p.tasks.forEach(t => {
    if (!t.due || t.status === 'na') return;
    events.push({ id:'task_'+t.id, title:t.name, date:t.due,
      dept:t.dept, type:'task', status:t.status, owner:t.owner, notes:t.notes });
  });
  if (p.launchDate) {
    events.push({ id:'launch', title:'🚀 LAUNCH — '+p.model,
      date:p.launchDate, dept:'launch', type:'launch', owner:'All Teams' });
  }
  p.retailers.forEach(r => {
    if (!r.launchDate || r.launchDate==='TBD' || r.launchDate==='') return;
    const d = new Date(r.launchDate);
    if (!isNaN(d.getTime())) {
      events.push({ id:'ret_'+r.id, title:r.name+' Go-Live',
        date:r.launchDate, dept:'retailer', type:'retailer', owner:'Sales' });
    }
  });
  (p.calEvents||[]).forEach(e => events.push(e));
  return events;
}

function eventsForDate(allEvents, year, month, day) {
  const key = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
  return allEvents.filter(e => e.date === key || e.date?.startsWith(key));
}

function buildDateKey(year, month, day) {
  return `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
}

function renderCalendar() {
  const p = activeProject();
  if (!p) return;
  if (!p.calEvents) p.calEvents = [];
  const allEvents = getCalEvents(p);
  const today = new Date();

  // Three months to show
  const months = [0,1,2].map(i => {
    const d = new Date(calStartMonth.getFullYear(), calStartMonth.getMonth()+i, 1);
    return { year:d.getFullYear(), month:d.getMonth() };
  });

  const rangeStart = months[0];
  const rangeEnd   = months[2];
  const rangeLabel =
    new Date(rangeStart.year,rangeStart.month).toLocaleDateString('en-US',{month:'long',year:'numeric'})
    + ' – ' +
    new Date(rangeEnd.year,rangeEnd.month).toLocaleDateString('en-US',{month:'long'});

  // Calendar empty state hint — show when no events exist yet
  const calIsEmpty = allEvents.length === 0;
  const calEmptyBanner = calIsEmpty ? `
    <div style="display:flex;align-items:center;gap:12px;
      background:var(--blu-b);border:1px solid rgba(80,144,255,.2);
      border-radius:8px;padding:12px 16px;margin-bottom:16px;">
      <div style="font-size:18px">📅</div>
      <div>
        <div style="font-size:12px;font-weight:600;color:var(--blu);margin-bottom:2px">Calendar is empty</div>
        <div style="font-size:11px;color:var(--ink3)">Events populate automatically when you set due dates on tasks in Command · Add a launch date in the project settings · Use <strong style="color:var(--ink2)">＋ Event</strong> to add campaign windows, embargoes, or asset deadlines manually</div>
      </div>
    </div>` : '';

  // --- TOP BAR ---
  let html = `
    <div class="cal-topbar">
      <div class="cal-title-group">
        <div class="cal-title">Marketing Calendar</div>
        <div class="cal-sub">${p.model}${p.name!=='TBD'?' · '+p.name:''} · Campaign deadlines, go-live dates & key milestones</div>
      </div>
      <div class="cal-controls">
        <button class="cal-nav-btn" onclick="calPrev()">‹</button>
        <div class="cal-range-label">${rangeLabel}</div>
        <button class="cal-nav-btn" onclick="calNext()">›</button>
        <button class="cal-today-btn" onclick="calToday()">Today</button>
        <button class="cal-add-btn" onclick="openAddCalEventModal()">＋ Event</button>
      </div>
    </div>
    ${calEmptyBanner}

    <div class="cal-legend">
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#e8304a"></span>Launch</div>
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#8b5cf6"></span>Retailer</div>
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#5090ff"></span>Product</div>
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#e8304a;opacity:.5"></span>Marketing</div>
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#2ecc82"></span>Sales</div>
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#f07832"></span>DTC</div>
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#d4a843"></span>Logistics</div>
      <div class="cal-leg-item"><span class="cal-leg-dot" style="background:#4dd9e0"></span>CX / Custom</div>
    </div>

    <div class="cal-three-wrap">`;

  // --- THREE MINI MONTHS ---
  months.forEach(({year, month}) => {
    const firstDay    = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month+1, 0).getDate();
    const daysInPrev  = new Date(year, month, 0).getDate();
    const mName = new Date(year,month).toLocaleDateString('en-US',{month:'long',year:'numeric'});
    const isExpanded = calExpandedMonth?.year===year && calExpandedMonth?.month===month;

    html += `
      <div class="cal-mini-month" id="mini-${year}-${month}">
        <div class="cmm-head" onclick="toggleExpandMonth(${year},${month})">
          <div class="cmm-name">${mName}</div>
          <div class="cmm-expand-hint">${isExpanded?'↑ Collapse':'↓ Expand'}</div>
        </div>
        <div class="cmm-days-header">${DAYS3.map(d=>`<div class="cmm-dh">${d}</div>`).join('')}</div>
        <div class="cmm-grid">`;

    // prev month overflow
    for (let i=0; i<firstDay; i++) {
      html += `<div class="cmm-cell other"><div class="cmm-num">${daysInPrev-firstDay+i+1}</div></div>`;
    }
    // current month
    for (let day=1; day<=daysInMonth; day++) {
      const isToday = today.getFullYear()===year && today.getMonth()===month && today.getDate()===day;
      const dateKey = buildDateKey(year, month, day);
      const isSelected = calSelectedDate === dateKey;
      const dayEvs = eventsForDate(allEvents, year, month, day);

      // Build colored dots (max 5)
      const dots = dayEvs.slice(0,5).map(e => {
        const c = EV_DOT_COLOR[e.type==='task'?e.dept:e.type] || '#6a6a7a';
        return `<span class="cmm-dot" style="background:${c}"></span>`;
      }).join('');

      html += `<div class="cmm-cell ${isToday?'today':''} ${isSelected?'selected':''}"
        onclick="selectCalDay('${dateKey}')" title="${dateKey}">
        <div class="cmm-num">${day}</div>
        ${dots ? `<div class="cmm-dots">${dots}</div>` : ''}
      </div>`;
    }
    // next month overflow
    const filled = firstDay + daysInMonth;
    const remain = (7-(filled%7))%7;
    for (let i=1; i<=remain; i++) {
      html += `<div class="cmm-cell other"><div class="cmm-num">${i}</div></div>`;
    }

    html += `</div></div>`; // close cmm-grid + cal-mini-month
  });

  html += `</div>`; // close cal-three-wrap

  // --- DETAIL DRAWER ---
  const drawerHidden = !calSelectedDate;
  html += `<div class="cal-drawer ${drawerHidden?'hidden':''}" id="calDrawer">`;

  if (calSelectedDate) {
    const [sy,sm,sd] = calSelectedDate.split('-').map(Number);
    const dateLabel = new Date(sy,sm-1,sd).toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
    const dayEvs = allEvents.filter(e=>e.date===calSelectedDate);
    html += `
      <div class="cal-drawer-head">
        <div>
          <div class="cdh-date">${dateLabel}</div>
          <div class="cdh-count">${dayEvs.length} event${dayEvs.length!==1?'s':''}</div>
        </div>
        <button class="cdh-close" onclick="closeDrawer()">✕</button>
      </div>
      <div class="cal-drawer-body">`;

    if (dayEvs.length===0) {
      html += `<div class="cdb-empty">No events on this date.</div>`;
    } else {
      dayEvs.forEach(ev => {
        const stripeColor = EV_DOT_COLOR[ev.type==='task'?ev.dept:ev.type] || '#6a6a7a';
        const evCls = DEPT_EV_CLASS[ev.type==='task'?ev.dept:ev.type] || 'ev-manual';
        const isDone = ev.status==='done';
        const statusCls = {done:'s-done',progress:'s-prog',blocked:'s-blk',na:'s-na'}[ev.status]||'';
        const statusLbl = {done:'Done',progress:'In Progress',blocked:'Blocked',na:'N/A'}[ev.status]||'';
        html += `
          <div class="cdb-event">
            <div class="cdb-stripe" style="background:${stripeColor}"></div>
            <div class="cdb-content">
              <div class="cdb-title ${isDone?'done-title':''}">${escHtml(ev.title)}</div>
              <div class="cdb-meta">
                <span class="cdb-dept ${evCls}" style="font-size:9px">${DEPT_CFG[ev.dept]?.label||ev.type||'Event'}</span>
                ${ev.owner?`<span class="cdb-owner">👤 <span>${escHtml(ev.owner)}</span></span>`:''}
                ${statusLbl?`<span class="spill ${statusCls}" style="cursor:default;font-size:9px">${statusLbl}</span>`:''}
              </div>
              ${ev.notes?`<div class="cdb-notes">${escHtml(ev.notes)}</div>`:''}
            </div>
          </div>`;
      });
    }
    html += `</div></div>`; // close drawer-body + drawer
  } else {
    html += `</div>`; // close empty drawer
  }

  // --- EXPANDED MONTH (if open) ---
  html += `<div class="cal-expanded ${calExpandedMonth?'open':''}" id="calExpanded">`;
  if (calExpandedMonth) {
    const {year:ey, month:em} = calExpandedMonth;
    const expName = new Date(ey,em).toLocaleDateString('en-US',{month:'long',year:'numeric'});
    const firstDay    = new Date(ey,em,1).getDay();
    const daysInMonth = new Date(ey,em+1,0).getDate();
    const daysInPrev  = new Date(ey,em,0).getDate();

    html += `
      <div class="cal-exp-head">
        <div class="cal-exp-name">${expName} — Full View</div>
        <button class="cal-exp-close" onclick="toggleExpandMonth(${ey},${em})">↑ Collapse</button>
      </div>
      <div class="cal-exp-grid">
        ${DAYS7.map(d=>`<div class="cal-exp-dh">${d}</div>`).join('')}`;

    for (let i=0; i<firstDay; i++) {
      html += `<div class="cal-exp-day other-month"><div class="cal-exp-num">${daysInPrev-firstDay+i+1}</div></div>`;
    }
    for (let day=1; day<=daysInMonth; day++) {
      const isToday2 = today.getFullYear()===ey && today.getMonth()===em && today.getDate()===day;
      const dateKey2 = buildDateKey(ey, em, day);
      const isSelected2 = calSelectedDate===dateKey2;
      const dayEvs2 = eventsForDate(allEvents, ey, em, day);
      html += `<div class="cal-exp-day ${isToday2?'today-exp':''} ${isSelected2?'selected-day':''}"
        onclick="selectCalDay('${dateKey2}')">
        <div class="cal-exp-num ${isToday2?'today-num':''}">${day}</div>`;
      dayEvs2.slice(0,3).forEach(ev2 => {
        const cls2 = DEPT_EV_CLASS[ev2.type==='task'?ev2.dept:ev2.type]||'ev-manual';
        const strike2 = ev2.status==='done'?'opacity:.4;text-decoration:line-through;':'';
        html += `<span class="cal-exp-ev ${cls2}" style="${strike2}" title="${escHtml(ev2.title)}">${escHtml(ev2.title)}</span>`;
      });
      if (dayEvs2.length>3) html += `<div class="cal-exp-more">+${dayEvs2.length-3}</div>`;
      html += `</div>`;
    }
    const filled2 = firstDay+daysInMonth;
    const remain2 = (7-(filled2%7))%7;
    for (let i=1; i<=remain2; i++) {
      html += `<div class="cal-exp-day other-month"><div class="cal-exp-num">${i}</div></div>`;
    }
    html += `</div>`; // close cal-exp-grid
  }
  html += `</div>`; // close cal-expanded

  // --- UPCOMING STRIP ---
  const upcoming = allEvents
    .filter(ev => {
      if (!ev.date) return false;
      const d = new Date(ev.date);
      const diff = Math.ceil((d-today)/(1000*60*60*24));
      return diff >= 0 && diff <= 90;
    })
    .sort((a,b)=>new Date(a.date)-new Date(b.date))
    .slice(0,15);

  html += `
    <div class="cal-upcoming-strip">
      <div class="cus-title">Upcoming · Next 90 Days</div>
      <div class="cus-row header">
        <div>Date</div><div>Event</div><div>Owner</div><div>Status</div>
      </div>`;

  if (upcoming.length===0) {
    html += `<div style="font-size:12px;color:var(--ink4);padding:12px 0;text-align:center;font-style:italic">No upcoming events in the next 90 days.</div>`;
  } else {
    upcoming.forEach(ev => {
      const d = new Date(ev.date);
      const diff = Math.ceil((d-today)/(1000*60*60*24));
      const dateStr = d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
      const dotColor = EV_DOT_COLOR[ev.type==='task'?ev.dept:ev.type]||'#6a6a7a';
      const urgency = diff<=7?'color:var(--red);font-weight:600':diff<=14?'color:var(--org)':'';
      const sc = {done:'s-done',progress:'s-prog',blocked:'s-blk',na:'s-na'}[ev.status]||'';
      const sl = {done:'Done',progress:'In Progress',blocked:'Blocked',na:'N/A'}[ev.status]||'–';
      html += `
        <div class="cus-row" style="cursor:pointer" onclick="selectCalDay('${ev.date}')">
          <div class="cus-date" style="${urgency}">
            <span style="display:inline-block;width:6px;height:6px;border-radius:1px;background:${dotColor};margin-right:5px;vertical-align:middle"></span>${dateStr}
          </div>
          <div class="cus-name">${escHtml(ev.title)}</div>
          <div class="cus-owner">${escHtml(ev.owner||'—')}</div>
          <div class="cus-badge">${sc?`<span class="spill ${sc}" style="cursor:default;font-size:9px">${sl}</span>`:'<span style="font-size:10px;color:var(--ink4)">–</span>'}</div>
        </div>`;
    });
  }
  html += `</div>`; // close upcoming-strip

  document.getElementById('calLayout').innerHTML = html;
}

function calPrev()  {
  calStartMonth = new Date(calStartMonth.getFullYear(), calStartMonth.getMonth()-1, 1);
  renderCalendar();
}
function calNext()  {
  calStartMonth = new Date(calStartMonth.getFullYear(), calStartMonth.getMonth()+1, 1);
  renderCalendar();
}
function calToday() {
  calStartMonth = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
  renderCalendar();
}

function selectCalDay(dateKey) {
  calSelectedDate = calSelectedDate===dateKey ? null : dateKey;
  // If clicking a date in a month not in current view, snap to it
  const [sy,sm] = dateKey.split('-').map(Number);
  const clickedMonth = new Date(sy, sm-1, 1);
  const endMonth = new Date(calStartMonth.getFullYear(), calStartMonth.getMonth()+2, 1);
  if (clickedMonth < calStartMonth || clickedMonth > endMonth) {
    calStartMonth = new Date(sy, sm-1, 1);
  }
  renderCalendar();
  // Scroll drawer into view
  if (calSelectedDate) {
    setTimeout(()=>{
      document.getElementById('calDrawer')?.scrollIntoView({behavior:'smooth',block:'nearest'});
    }, 50);
  }
}

function closeDrawer() {
  calSelectedDate = null;
  renderCalendar();
}

function toggleExpandMonth(year, month) {
  if (calExpandedMonth?.year===year && calExpandedMonth?.month===month) {
    calExpandedMonth = null;
  } else {
    calExpandedMonth = {year, month};
  }
  renderCalendar();
  if (calExpandedMonth) {
    setTimeout(()=>{
      document.getElementById('calExpanded')?.scrollIntoView({behavior:'smooth',block:'start'});
    }, 50);
  }
}

// Add calendar event modal
let _calEventProjectId = null;
function openAddCalEventModal() {
  _calEventProjectId = state.activeProjectId;
  // Pre-fill date if one is selected
  if (calSelectedDate) document.getElementById('ce-date').value = calSelectedDate;
  openModal('addCalEventModal');
}
function saveCalEvent() {
  const p = getProject(_calEventProjectId);
  if (!p) return;
  const title = document.getElementById('ce-title').value.trim();
  const date  = document.getElementById('ce-date').value;
  if (!title || !date) return;
  if (!p.calEvents) p.calEvents = [];
  p.calEvents.push({
    id:'manual_'+Date.now(),
    title, date,
    dept: document.getElementById('ce-dept').value,
    notes: document.getElementById('ce-notes').value,
    owner: document.getElementById('ce-owner').value,
    type:'manual',
  });
  save();
  closeModal('addCalEventModal');
  ['ce-title','ce-date','ce-notes','ce-owner'].forEach(id=>document.getElementById(id).value='');
  renderCalendar();
}

// ═══════════════════════════════════════════
//  MODAL UTILITIES
// ═══════════════════════════════════════════
function openModal(id) { document.getElementById(id)?.classList.add('open'); }
function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
document.querySelectorAll('.modal-ov').forEach(el => {
  el.addEventListener('click', e => { if(e.target===el) el.classList.remove('open'); });
});

// ═══════════════════════════════════════════
//  MASTER RENDER
// ═══════════════════════════════════════════
function renderAll() {
  renderRail();
  renderTopbar();
  if (state.sprintMode) { renderSprint(); return; }
  const v = state.activeView || 'home';
  if (v==='home')      renderHome();
  if (v==='tracker')   renderTracker();
  if (v==='retailers') renderRetailers();
  if (v==='samples')   renderSamples();
  if (v==='sales')     renderSales();
  if (v==='exec')      renderExec();
  if (v==='calendar')  renderCalendar();
  if (v==='sprint')    renderSprint();
}

// ═══════════════════════════════════════════
//  BOOT — async so Supabase load can await
// ═══════════════════════════════════════════
(async function boot() {
  // Show connecting state while we hit Supabase
  const railList = document.getElementById('railList');
  if (railList) railList.innerHTML =
    '<div style="padding:16px 12px;font-size:11px;color:var(--ink4);font-style:italic;text-align:center;">Connecting...</div>';

  await load();

  // Deduplicate on boot
  const seen = new Set();
  state.projects = (state.projects||[]).filter(p => {
    if (seen.has(p.id)) return false;
    seen.add(p.id); return true;
  });

  seedProjects();
  startAutoSave();
  startRealtime();
  renderAll();
  showView(state.activeView || 'home');
})();
</script>
