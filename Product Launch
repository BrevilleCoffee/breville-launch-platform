<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Breville Americas · Launch Platform</title>
<!-- Supabase client -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@400;500&family=Playfair+Display:wght@400;500;600&family=Zilla+Slab:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════
   DESIGN SYSTEM v2 — BREVILLE AMERICAS
═══════════════════════════════════════ */
:root {
  /* ── SURFACES: clear 4-step ladder ── */
  --bg:   #f5f2ed;   /* page ground — warm parchment */
  --rail: #fffef9;   /* rail / cards — warm white */
  --surf0:#f0ece5;   /* structural chrome — slightly darker than ground */
  --surf1:#fffef9;   /* card / content surface — white */
  --surf2:#ede9e2;   /* secondary surface — visible step */
  --surf3:#e2ddd5;   /* tertiary — input fields, hover */

  /* ── BORDERS: 3 clear weights ── */
  --bdr0: #ddd7cc;   /* default — visible but quiet */
  --bdr:  #c8c0b4;   /* emphasis — section dividers */
  --bdr2: #b0a89a;   /* strong — active states */
  --bdr3: #8a8278;   /* heaviest — focus rings */

  /* ── TYPOGRAPHY: 4-step ink scale ── */
  --ink:  #1e1a14;   /* headings — near black, warm */
  --ink2: #4a4238;   /* body text */
  --ink3: #7a7268;   /* secondary / labels */
  --ink4: #a8a098;   /* placeholders / hints */

  /* ── SEMANTIC COLORS: richer against warm ground ── */
  --red:  #c0281e; --red-a:rgba(192,40,30,.10);  --red-b:rgba(192,40,30,.05);
  --org:  #c05818; --org-a:rgba(192,88,24,.10);
  --gld:  #9a7018; --gld-a:rgba(154,112,24,.10);
  --grn:  #28825a; --grn-a:rgba(40,130,90,.10);  --grn-b:rgba(40,130,90,.05);
  --blu:  #2858b8; --blu-a:rgba(40,88,184,.10);  --blu-b:rgba(40,88,184,.05);
  --teal: #2890a0; --teal-a:rgba(40,144,160,.10);
  --coffee:#a85e18;

  /* ── RAIL ACCENT ── */
  --rail-border:1px solid var(--bdr0);
  --rail-accent-w: 4px;   /* wider active indicator */

  /* ── FONTS ── */
  --f-display: 'Bebas Neue', sans-serif;
  --f-serif:   'Playfair Display', Georgia, serif;
  --f-slab:    'Zilla Slab', 'Archer', Georgia, serif;
  --f-ui:      'Inter', 'DM Sans', sans-serif;
  --f-body:    'DM Sans', sans-serif;
  --f-mono:    'DM Mono', monospace;
  --RAIL: 256px;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{font-family:var(--f-body);background:var(--bg);color:var(--ink);display:flex;flex-direction:column;font-size:13px;overflow:hidden;}
::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--bdr2);border-radius:2px;}

/* SYNC PULSE */
@keyframes syncFlash { 0%{color:rgba(40,210,128,.9)} 100%{color:rgba(40,210,128,.0)} }
#syncPulse.pulse { animation: syncFlash 1.2s ease-out forwards; }

/* APP HEADER — full width brand bar */
.app-header {
  width:100%; flex-shrink:0;
  height:76px;
  background:#1a1610;
  display:flex; align-items:center;
  padding:0 28px;
  gap:20px;
  border-bottom:3px solid var(--coffee);
  z-index:100;
}
.app-header-brand {
  font-family:var(--f-slab);
  font-size:21px; font-weight:600; letter-spacing:.5px;
  color:#fffef9; line-height:1;
  white-space:nowrap;
}
.app-header-brand span { color:var(--coffee); }
.app-header-divider {
  width:1px; height:28px;
  background:rgba(255,254,249,.15); flex-shrink:0;
}
.app-header-sub {
  font-family:var(--f-ui);
  font-size:11px; font-weight:500;
  letter-spacing:2.5px; text-transform:uppercase;
  color:rgba(255,254,249,.5);
  white-space:nowrap;
}
.app-header-right {
  margin-left:auto;
  font-family:var(--f-ui);
  font-size:10px; font-weight:400;
  letter-spacing:1.5px; text-transform:uppercase;
  color:rgba(255,254,249,.28);
}

/* RAIL */
.workspace{display:flex;flex:1;overflow:hidden;min-height:0;}
.rail{width:var(--RAIL);flex-shrink:0;background:#fffef9;border-right:1px solid var(--bdr0);box-shadow:2px 0 16px rgba(80,60,20,.06);display:flex;flex-direction:column;height:100vh;overflow:hidden;}
.rail-head{display:none;}
.rail-logo{font-family:var(--f-display);font-size:20px;letter-spacing:2.5px;color:var(--ink);line-height:1;}
.rail-logo span{color:var(--coffee);}
.rail-tagline{font-size:10px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink4);margin-top:4px;}
.rail-sec{font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--ink3);font-family:var(--f-ui);padding:14px 16px 8px;flex-shrink:0;border-bottom:1px solid var(--bdr0);margin-bottom:4px;}
.rail-list{flex:1;overflow-y:auto;padding:4px 8px 8px;}
.rpill{border-radius:10px;padding:11px 12px 10px;margin-bottom:4px;cursor:pointer;border:1px solid transparent;transition:background .12s,border-color .12s;position:relative;}
.rpill:hover{background:var(--surf1);border-color:var(--bdr0);}
.rpill.active{background:var(--surf2);border-color:var(--bdr);}
.rpill.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:10px 0 0 10px;background:var(--_cat,var(--blu));}
.rpill-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.rpill-model{font-family:var(--f-ui);font-size:10px;font-weight:500;color:var(--ink3);letter-spacing:.5px;}
.rpill-pct{font-family:var(--f-mono);font-size:11px;font-weight:500;}
.rpill-name{font-size:12px;font-weight:600;color:var(--ink);margin-bottom:6px;line-height:1.3;}
.rpill-stage{font-size:10px;font-weight:600;letter-spacing:.3px;padding:3px 8px;border-radius:5px;display:inline-block;margin-bottom:7px;cursor:pointer;user-select:none;transition:opacity .12s;}
.rpill-stage:hover{opacity:.75;}
.rpill-bar{height:2px;background:var(--bdr0);border-radius:1px;overflow:hidden;}
.rpill-fill{height:100%;border-radius:1px;transition:width .4s;}
.rpill-edit{position:absolute;top:10px;right:10px;background:none;border:none;cursor:pointer;color:var(--ink4);font-size:12px;padding:2px 4px;border-radius:4px;opacity:0;transition:opacity .15s;z-index:2;}
.rpill:hover .rpill-edit{opacity:1;}
.rpill-edit:hover{color:var(--blu);background:var(--blu-a);}
.rail-foot{padding:8px;border-top:2px solid var(--bdr0);flex-shrink:0;display:flex;flex-direction:column;gap:3px;}
.rfbtn{width:100%;padding:8px 12px;border-radius:8px;border:1px solid transparent;background:transparent;color:var(--ink3);font-family:var(--f-body);font-size:12px;font-weight:500;cursor:pointer;transition:all .12s;text-align:left;display:flex;align-items:center;gap:8px;}
.rfbtn:hover{background:var(--surf2);color:var(--ink);border-color:var(--bdr0);}
.rfbtn.on{background:var(--blu-a);border-color:rgba(80,144,255,.3);color:var(--blu);}
.rfbtn-icon{font-size:13px;opacity:.7;}

/* MAIN / TOPBAR */
.main{flex:1;display:flex;flex-direction:column;min-height:100vh;overflow:hidden;}
.topbar{height:56px;background:rgba(255,254,249,.98);border-bottom:2px solid var(--bdr0);backdrop-filter:blur(16px);display:flex;align-items:center;justify-content:space-between;padding:0 20px;flex-shrink:0;gap:12px;}
.tb-left{display:flex;align-items:center;gap:12px;min-width:0;}
.tb-title{font-family:var(--f-serif);font-size:16px;font-weight:600;letter-spacing:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:260px;flex-shrink:0;}
.tb-model{font-family:var(--f-mono);font-size:10px;padding:3px 8px;background:var(--surf2);border:1px solid var(--bdr);border-radius:5px;color:var(--ink3);white-space:nowrap;flex-shrink:0;}
.tb-tabs{display:flex;gap:3px;background:var(--surf2);padding:3px;border-radius:9px;border:1px solid var(--bdr0);}
.tbtab{padding:6px 14px;border-radius:7px;border:1px solid transparent;background:transparent;color:var(--ink3);font-family:var(--f-ui);font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;white-space:nowrap;position:relative;letter-spacing:.1px;}
.tbtab:hover{background:var(--surf2);color:var(--ink2);border-color:var(--bdr0);}
.tbtab.active{background:#fffef9;color:var(--ink);font-weight:600;border-color:var(--bdr);box-shadow:0 1px 4px rgba(80,50,20,.10);}
.tbtab.active::after{content:'';position:absolute;bottom:-2px;left:12%;right:12%;height:2px;background:var(--coffee);border-radius:2px 2px 0 0;opacity:.7;}
.tb-right{display:flex;gap:6px;align-items:center;flex-shrink:0;}
.tbact{padding:5px 13px;border-radius:6px;font-family:var(--f-body);font-size:12px;font-weight:600;cursor:pointer;transition:all .12s;white-space:nowrap;}
.tbact.ghost{background:transparent;border:1px solid var(--bdr2);color:var(--ink3);}
.tbact.ghost:hover{color:var(--ink);border-color:var(--bdr3);}
.tbact.primary{background:var(--red);border:1px solid transparent;color:#fff;}
.tbact.primary:hover{opacity:.85;}
.content{flex:1;overflow-y:auto;}
.view{display:none;}.view.active{display:block;}

/* HOME */
.home-wrap{padding:24px;}
.home-hero{margin-bottom:24px;}
.home-eyebrow{font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--coffee);margin-bottom:6px;font-family:var(--f-ui);}
.home-title{font-family:var(--f-display);font-size:42px;letter-spacing:.5px;line-height:1;margin-bottom:5px;}
.home-sub{font-size:12px;color:var(--ink3);}
.home-kpis{display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap;}
.hkpi{background:#fffef9;border:1px solid var(--bdr);border-radius:10px;padding:14px 18px;display:flex;flex-direction:column;gap:4px;box-shadow:0 2px 6px rgba(80,50,20,.08);border-top:3px solid var(--bdr2);}
.hkpi-val{font-family:var(--f-display);font-size:32px;line-height:1;}
.hkpi-lbl{font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--ink3);}
.hkpi-sub{font-size:11px;color:var(--ink4);}
.home-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(268px,1fr));gap:12px;}
.hpcard{background:var(--surf1);border:1px solid var(--bdr0);border-radius:12px;overflow:hidden;cursor:pointer;transition:border-color .15s,transform .15s,box-shadow .15s;}
.hpcard:hover{border-color:var(--bdr2);transform:translateY(-2px);box-shadow:0 10px 28px rgba(80,50,20,.15);}
.hpcard-bar{height:3px;}
.hpcard-body{padding:16px;}
.hpcard-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.hpcard-model{font-family:var(--f-mono);font-size:10px;color:var(--ink3);}
.hpcard-actions{display:flex;align-items:center;gap:8px;}
.hpcard-pct{font-family:var(--f-mono);font-size:15px;font-weight:500;}
.hpcard-edit{background:none;border:none;cursor:pointer;color:var(--ink4);font-size:12px;padding:2px 5px;border-radius:4px;transition:all .12s;opacity:0;}
.hpcard:hover .hpcard-edit{opacity:1;}
.hpcard-edit:hover{color:var(--blu);background:var(--blu-a);}
.hpcard-name{font-family:var(--f-serif);font-size:19px;font-weight:500;letter-spacing:0;margin-bottom:8px;line-height:1.25;}
.hpcard-tags{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;align-items:center;}
.hptag{font-size:10px;font-weight:600;letter-spacing:.3px;padding:3px 8px;border-radius:5px;}
.hpcard-progress{height:3px;background:var(--bdr0);border-radius:2px;overflow:hidden;margin-bottom:12px;}
.hpcard-fill{height:100%;border-radius:2px;transition:width .4s;}
.hpcard-foot{display:flex;align-items:center;justify-content:space-between;padding-top:10px;border-top:1px solid var(--bdr0);font-size:11px;color:var(--ink3);}
.add-project-card{background:transparent;border:1px dashed var(--bdr2);border-radius:12px;padding:24px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;min-height:148px;gap:10px;color:var(--ink4);font-size:12px;font-weight:500;}
.add-project-card:hover{border-color:var(--blu);color:var(--blu);background:var(--blu-b);}
.add-project-card .plus{font-size:28px;line-height:1;}

/* COMMAND VIEW */
.tracker-layout{display:grid;grid-template-columns:224px 1fr;min-height:calc(100vh - 132px);}
.tracker-hero{grid-column:1/-1;padding:20px 24px 18px;display:flex;align-items:flex-end;justify-content:space-between;gap:20px;border-bottom:2px solid var(--bdr);background:#f0ece5;}
.th-left{}
.th-eyebrow{font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:5px;}
.th-title{font-family:var(--f-serif);font-size:28px;font-weight:600;letter-spacing:-.3px;line-height:1.1;}
.th-kpis{display:flex;gap:10px;flex-shrink:0;}
.thk{background:#fffef9;border:1px solid var(--bdr);border-radius:8px;padding:10px 16px;text-align:center;min-width:68px;box-shadow:0 2px 6px rgba(80,50,20,.08);}
.thk-val{font-family:var(--f-display);font-size:24px;line-height:1;}
.thk-lbl{font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--ink3);margin-top:3px;}
.dept-sidebar{border-right:2px solid var(--bdr);padding:8px 0;overflow-y:auto;background:#eee9e0;}
.dbtn{width:calc(100% - 16px);margin:2px 8px;display:flex;align-items:center;gap:10px;padding:9px 11px;background:transparent;border:1px solid transparent;border-radius:8px;cursor:pointer;transition:all .15s;text-align:left;}
.dbtn:hover{background:#fffef9;border-color:var(--bdr0);box-shadow:0 1px 4px rgba(80,50,20,.07);}
.dbtn.active{background:#fffef9;border-color:var(--bdr);box-shadow:0 2px 6px rgba(80,50,20,.10);position:relative;}.dbtn.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:3px;background:var(--_dc,var(--coffee));border-radius:0 2px 2px 0;}
.dbtn-dot{width:8px;height:8px;border-radius:3px;flex-shrink:0;}
.dbtn-name{font-size:12px;font-weight:500;color:var(--ink2);flex:1;}
.dbtn.active .dbtn-name{color:var(--ink);font-weight:700;}
.dbtn-count{font-family:var(--f-mono);font-size:10px;color:var(--ink3);background:var(--surf2);border:1px solid var(--bdr0);border-radius:4px;padding:1px 5px;}
.dbtn-bar{height:3px;background:var(--bdr0);border-radius:2px;margin:0 20px 6px;overflow:hidden;}
.dbtn-fill{height:100%;border-radius:1px;transition:width .3s;}
.task-area{padding:0;overflow-y:auto;}
.dept-hdr{display:flex;align-items:center;justify-content:space-between;padding:16px 20px 14px;border-bottom:2px solid var(--bdr);background:#eee9e0;position:sticky;top:0;z-index:10;}
.dept-hdr-left{display:flex;align-items:center;gap:10px;}
.dept-hdr-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.dept-hdr-title{font-family:var(--f-display);font-size:22px;letter-spacing:.3px;}
.dept-hdr-sub{font-size:11px;color:var(--ink3);}
.dept-ring{position:relative;width:44px;height:44px;flex-shrink:0;}
.dept-ring svg{transform:rotate(-90deg);}
.dept-ring-pct{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--f-mono);font-size:10px;font-weight:500;}
.task-table{width:100%;border-collapse:collapse;}
.task-table th{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--ink2);padding:10px 12px 9px;text-align:left;border-bottom:2px solid var(--bdr);background:#ede8df;position:sticky;top:73px;z-index:9;}
.task-table th:last-child{text-align:right;padding-right:16px;}
.trow{border-bottom:1px solid var(--bdr0);transition:background .1s;}.trow:nth-child(even){background:#f8f4ee;}
.trow:hover{background:#ede8df!important;}
.trow td{padding:10px 12px;vertical-align:middle;}
.tchk{width:16px;height:16px;border-radius:4px;border:1.5px solid var(--bdr2);background:transparent;cursor:pointer;appearance:none;-webkit-appearance:none;flex-shrink:0;transition:all .13s;}
.tchk:checked{background:var(--grn);border-color:var(--grn);background-image:url("data:image/svg+xml,%3Csvg width='9' height='7' viewBox='0 0 9 7' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 3.5L3.2 5.5L8 1' stroke='white' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:center;}
.tname{font-size:12px;color:var(--ink);line-height:1.4;}
.tname.done{color:var(--ink4);text-decoration:line-through;}
.tnote{font-size:10px;color:var(--ink3);margin-top:2px;}
.towner{font-size:10px;color:var(--ink2);}
.tdue{font-family:var(--f-mono);font-size:10px;color:var(--ink3);white-space:nowrap;}
.tdue.late{color:var(--red);}
.tdue.soon{color:var(--org);}

/* Inline inputs — visible affordance */
.inline-input{background:transparent;border:none;color:var(--ink);font-family:var(--f-body);font-size:12px;padding:3px 6px;outline:none;width:100%;border-radius:5px;transition:background .12s;cursor:text;}
.inline-input:hover{background:var(--surf2);}
.inline-input:focus{background:var(--surf2);outline:1.5px solid var(--blu);outline-offset:0;}
.inline-input::placeholder{color:var(--ink4);}
.inline-date{background:transparent;border:none;border-radius:5px;color:var(--ink3);font-family:var(--f-mono);font-size:10px;padding:3px 4px;outline:none;color-scheme:light;transition:background .12s;cursor:pointer;}
.inline-date:hover{background:var(--surf2);}
.inline-date:focus{background:var(--surf2);outline:1.5px solid var(--blu);}

/* Status pills */
.spill{display:inline-flex;align-items:center;padding:3px 9px;border-radius:12px;font-size:10px;font-weight:600;white-space:nowrap;cursor:pointer;user-select:none;transition:opacity .1s;letter-spacing:.2px;}
.spill:hover{opacity:.75;}
.s-done{background:var(--grn-a);color:var(--grn);}
.s-prog{background:var(--org-a);color:var(--org);}
.s-blk{background:var(--red-a);color:var(--red);}
.s-na{background:var(--surf3);color:var(--ink4);}
.add-row{display:flex;align-items:center;gap:8px;padding:11px 12px;cursor:pointer;color:var(--ink4);font-size:12px;transition:all .13s;border-top:1px solid var(--bdr0);}
.add-row:hover{color:var(--blu);background:var(--blu-b);}

/* RETAILERS */
.retailer-layout{padding:20px 24px;}
.ret-hero{margin-bottom:20px;}
.ret-title{font-family:var(--f-display);font-size:28px;letter-spacing:.3px;margin-bottom:4px;}
.ret-sub{font-size:12px;color:var(--ink3);}
.ret-tier-lbl{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink3);margin-bottom:10px;padding-bottom:8px;border-bottom:2px solid var(--bdr);}
.ret-tier{margin-bottom:28px;}
.ret-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:12px;}
.rcard{background:var(--surf1);border:1px solid var(--bdr0);border-radius:12px;overflow:hidden;transition:border-color .15s;}
.rcard:hover{border-color:var(--bdr2);}
.rcard-head{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-bottom:2px solid var(--bdr);background:#f5f2ed;}
.rcard-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0;}
.rcard-name{font-size:13px;font-weight:600;margin-left:9px;}
.rcard-launch{font-size:10px;color:var(--ink3);margin-top:2px;}
.rcard-pct{font-family:var(--f-mono);font-size:14px;font-weight:500;}
.rcard-bar{height:2px;background:var(--bdr0);}
.rcard-bar-fill{height:100%;transition:width .4s;}
.rcard-tasks{padding:4px 0;}
.rtask{display:flex;align-items:center;gap:9px;padding:6px 14px;cursor:pointer;transition:background .1s;}
.rtask:hover{background:var(--surf2);}
.rtask-name{font-size:11px;color:var(--ink3);flex:1;line-height:1.3;}
.rtask-name.done{color:var(--ink4);text-decoration:line-through;}
.rcard-links{display:flex;align-items:center;gap:6px;padding:10px 14px;border-top:1px solid var(--bdr0);flex-wrap:wrap;background:var(--surf0);}
.rlink{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:6px;font-size:10px;font-weight:600;text-decoration:none;cursor:pointer;transition:opacity .12s;border:1px solid;white-space:nowrap;}
.rlink:hover{opacity:.75;}
.rlink-home{background:var(--surf3);border-color:var(--bdr2);color:var(--ink2);}
.rlink-brand{background:var(--blu-a);border-color:rgba(80,144,255,.25);color:var(--blu);}
.rlink-pdp-live{background:var(--grn-a);border-color:rgba(40,216,128,.25);color:var(--grn);}
.rlink-pdp-pending{background:var(--surf2);border-color:var(--bdr);color:var(--ink4);cursor:default;}
.rlink-pdp-pending:hover{opacity:1;}
.pdp-input-wrap{display:flex;align-items:center;gap:6px;flex:1;min-width:160px;}
.pdp-url-input{flex:1;background:var(--surf2);border:1px solid var(--bdr);border-radius:6px;color:var(--ink2);font-family:var(--f-body);font-size:10px;padding:4px 8px;outline:none;}
.pdp-url-input:focus{border-color:var(--blu);color:var(--ink);}
.pdp-url-input::placeholder{color:var(--ink4);}

/* SAMPLES */
.samples-layout{padding:20px 24px;}
.samples-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(256px,1fr));gap:12px;margin-bottom:20px;}
.scard{background:var(--surf1);border:1px solid var(--bdr0);border-radius:10px;overflow:hidden;}
.scard-type{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--coffee);padding:11px 14px 9px;border-bottom:2px solid var(--bdr);background:#ede9e0;}
.scard-row{display:flex;justify-content:space-between;align-items:center;padding:8px 14px;border-bottom:1px solid var(--bdr0);font-size:12px;}
.scard-row:last-child{border-bottom:none;}
.scard-lbl{color:var(--ink3);font-size:11px;}
.scard-val{font-weight:600;}
.sqty{background:var(--surf2);border:1px solid var(--bdr);border-radius:6px;color:var(--ink);font-family:var(--f-mono);font-size:14px;width:64px;text-align:center;padding:4px 6px;outline:none;}
.sqty:focus{border-color:var(--blu);}

/* EXECUTIVE */
.exec-layout{padding:28px;max-width:920px;margin:0 auto;}
.exec-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;padding-bottom:20px;border-bottom:3px solid var(--bdr0);}
.exec-title{font-family:var(--f-display);font-size:44px;letter-spacing:.5px;line-height:1;}
.exec-sub{font-size:12px;color:var(--ink3);margin-top:4px;}
.exec-date{text-align:right;font-size:11px;color:var(--ink3);}
.exec-date strong{display:block;font-size:15px;color:var(--ink);margin-bottom:3px;}
.exec-donut-wrap{display:grid;grid-template-columns:160px 1fr;gap:20px;background:var(--surf1);border:1px solid var(--bdr0);border-radius:12px;padding:20px;margin-bottom:18px;align-items:center;}
.exec-donut{position:relative;width:140px;height:140px;}
.exec-donut svg{transform:rotate(-90deg);}
.exec-donut-mid{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.exec-donut-pct{font-family:var(--f-display);font-size:40px;line-height:1;}
.exec-donut-lbl{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--ink3);margin-top:2px;}
.exec-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.es{background:var(--surf2);border:1px solid var(--bdr0);border-radius:8px;padding:12px;}
.es-val{font-family:var(--f-display);font-size:28px;line-height:1;}
.es-lbl{font-size:10px;letter-spacing:.5px;text-transform:uppercase;color:var(--ink3);margin-top:4px;}
.exec-dept-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px;}
.edc{background:#fffef9;border:1px solid var(--bdr0);border-radius:10px;padding:14px;border-top:3px solid var(--bdr0);}
.edc-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.edc-name{font-size:12px;font-weight:600;}
.edc-pct{font-family:var(--f-display);font-size:22px;}
.edc-bar{height:4px;background:var(--bdr0);border-radius:2px;overflow:hidden;margin-bottom:7px;}
.edc-fill{height:100%;border-radius:2px;transition:width .4s;}
.edc-counts{font-size:10px;color:var(--ink3);display:flex;gap:10px;}
.edc-dot{display:inline-block;width:5px;height:5px;border-radius:50%;margin-right:3px;}
.exec-blocks{background:var(--red-b);border:1px solid rgba(240,61,90,.15);border-radius:10px;padding:16px;}
.exec-blocks-title{font-family:var(--f-display);font-size:18px;color:var(--red);margin-bottom:10px;}
.eb-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid rgba(240,61,90,.08);font-size:11px;}
.eb-row:last-child{border-bottom:none;}

/* SPRINT */
.sprint-wrap{padding:20px 24px;}
.sprint-hero{margin-bottom:18px;}
.sprint-title{font-family:var(--f-display);font-size:28px;letter-spacing:.3px;margin-bottom:4px;}
.sprint-sub{font-size:12px;color:var(--ink3);}
.sprint-selectors{display:flex;gap:14px;margin-bottom:20px;flex-wrap:wrap;}
.sprint-sel{display:flex;flex-direction:column;gap:5px;}
.sprint-sel label{font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--ink3);}
.sprint-sel select{background:var(--surf2);border:1px solid var(--bdr);border-radius:8px;color:var(--ink);font-family:var(--f-body);font-size:12px;padding:7px 12px;outline:none;cursor:pointer;min-width:210px;}
.sprint-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.sprint-col{background:var(--surf1);border:1px solid var(--bdr0);border-radius:12px;overflow:hidden;}
.sprint-col-head{padding:14px 16px;border-bottom:2px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;background:#eee9e0;}
.sch-model{font-family:var(--f-mono);font-size:10px;color:var(--ink3);margin-bottom:2px;}
.sch-name{font-family:var(--f-display);font-size:18px;letter-spacing:.3px;}
.sch-pct{font-family:var(--f-mono);font-size:16px;font-weight:500;}
.sprint-body{padding:14px;}
.sprint-dept-section{margin-bottom:14px;}
.sds-lbl{font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;margin-bottom:7px;}
.sprint-task{display:flex;align-items:flex-start;gap:9px;padding:7px 0;border-bottom:1px solid var(--bdr0);}
.sprint-task:last-child{border-bottom:none;}
.st-bullet{width:5px;height:5px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.st-text{font-size:12px;color:var(--ink2);flex:1;line-height:1.4;}
.st-owner{font-size:11px;color:var(--ink3);white-space:nowrap;font-weight:500;}
.sprint-empty{padding:20px;font-size:12px;color:var(--ink4);text-align:center;font-style:italic;}
.sprint-pulse{margin-top:14px;padding:12px 14px;background:var(--surf0);border:1px solid var(--bdr0);border-radius:10px;}
.sp-title{font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--ink4);margin-bottom:10px;}
.sp-numbers{display:flex;gap:20px;}
.sp-num{text-align:center;}
.sp-val{font-family:var(--f-display);font-size:24px;line-height:1;}
.sp-lbl{font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--ink4);margin-top:2px;}

/* MODALS */
.modal-ov{display:none;position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.8);backdrop-filter:blur(8px);align-items:center;justify-content:center;}
.modal-ov.open{display:flex;}
.modal{background:var(--surf1);border:1px solid var(--bdr);border-radius:16px;padding:28px;width:490px;max-width:95vw;max-height:88vh;overflow-y:auto;}
.m-title{font-family:var(--f-display);font-size:22px;letter-spacing:.3px;margin-bottom:20px;}
.mf{margin-bottom:14px;}
.ml{font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--ink3);display:block;margin-bottom:6px;}
.mi,.ms,.mta{width:100%;background:var(--surf2);border:1px solid var(--bdr);border-radius:8px;color:var(--ink);font-family:var(--f-body);font-size:13px;padding:9px 12px;outline:none;}
.mi:focus,.ms:focus,.mta:focus{border-color:var(--blu);}
.ms option{background:var(--surf2);}
.mta{resize:vertical;min-height:64px;}
.m-acts{display:flex;gap:8px;margin-top:20px;}
.m-save{flex:1;padding:10px;background:var(--blu);color:#fff;border:none;border-radius:8px;font-family:var(--f-body);font-size:13px;font-weight:600;cursor:pointer;}
.m-save:hover{opacity:.85;}
.m-cancel{padding:10px 16px;background:transparent;border:1px solid var(--bdr);color:var(--ink3);border-radius:8px;font-family:var(--f-body);font-size:13px;cursor:pointer;transition:all .12s;}
.m-cancel:hover{border-color:var(--bdr2);color:var(--ink2);}
.stage-toggle-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px;}
.stg-btn{padding:7px 14px;border-radius:7px;border:1px solid var(--bdr);background:transparent;color:var(--ink3);font-family:var(--f-body);font-size:11px;font-weight:600;cursor:pointer;transition:all .12s;}
.stg-btn:hover{border-color:var(--bdr2);color:var(--ink2);}
.stg-btn.active{color:#fff;}
.lock-banner{display:none;position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:var(--surf2);border:1px solid var(--bdr2);color:var(--ink2);padding:7px 18px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:.5px;z-index:400;}
.lock-banner.on{display:block;}

/* FORECAST TAB */
.sales-layout{padding:20px 24px;}
.sc-toggle-row{display:flex;align-items:center;gap:10px;}
.sc-toggle{display:flex;gap:3px;background:var(--surf2);padding:3px;border-radius:8px;border:1px solid var(--bdr);}
.sc-tog-btn{padding:5px 16px;border-radius:6px;border:none;background:transparent;cursor:pointer;font-family:var(--f-body);font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;transition:all .15s;color:var(--ink3);}
.sc-tog-btn.likely.on{background:#1a5c3a;color:#28d880;}
.sc-tog-btn.homerun.on{background:#1a2e6e;color:#7aabff;}
.sales-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:20px;}
.skpi{background:#fffef9;border:1px solid var(--bdr);border-radius:10px;padding:14px;box-shadow:0 2px 6px rgba(80,50,20,.07);border-top:3px solid var(--bdr2);}
.skpi-val{font-family:var(--f-display);font-size:28px;line-height:1;}
.skpi-lbl{font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--ink3);margin-top:4px;}
.skpi-sub{font-size:11px;color:var(--ink4);margin-top:2px;}
.sales-main{display:grid;grid-template-columns:1fr 280px;gap:14px;margin-bottom:14px;}
.sales-table-card{background:var(--surf1);border:1px solid var(--bdr0);border-radius:10px;overflow:hidden;}
.sales-table{width:100%;border-collapse:collapse;}
.sales-table th{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--ink2);padding:10px 12px;text-align:right;border-bottom:2px solid var(--bdr);background:#ede8df;}
.sales-table th:first-child{text-align:left;}
.sales-table td{padding:10px 12px;font-size:12px;border-bottom:1px solid var(--bdr0);vertical-align:middle;}
.sales-table td:not(:first-child){text-align:right;font-family:var(--f-mono);}
.sales-table tfoot td{font-weight:700;background:var(--surf0);font-size:13px;border-bottom:none;}
.sales-table tr:last-child td{border-bottom:none;}
.st-dot{display:inline-block;width:6px;height:6px;border-radius:1px;margin-right:6px;vertical-align:middle;}
.st-retailer{font-weight:600;color:var(--ink);}
.po-input{background:var(--surf2);border:1px solid var(--bdr);border-radius:6px;color:var(--ink);font-family:var(--f-mono);font-size:12px;width:72px;text-align:right;padding:4px 7px;outline:none;}
.po-input:focus{border-color:var(--blu);}
.var-pos{color:var(--grn);font-weight:600;}
.var-neg{color:var(--red);font-weight:600;}
.fill-cell{display:flex;align-items:center;gap:6px;justify-content:flex-end;}
.fill-bar-wrap{width:44px;height:4px;background:var(--bdr0);border-radius:2px;overflow:hidden;}
.fill-bar-fill{height:100%;border-radius:2px;transition:width .4s;}
.sales-right{display:flex;flex-direction:column;gap:12px;}
.sales-info-card{background:var(--surf1);border:1px solid var(--bdr0);border-radius:10px;padding:14px;}
.sic-title{font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--ink4);margin-bottom:10px;}
.sic-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--bdr0);font-size:12px;}
.sic-row:last-child{border-bottom:none;}
.sic-lbl{color:var(--ink3);}
.sic-val{font-family:var(--f-mono);font-weight:500;color:var(--ink);}
.sic-val.pos{color:var(--grn);}
.sic-val.neg{color:var(--red);}
.sic-val.gold{color:var(--gld);}
.num-input{background:transparent;border:none;border-radius:4px;color:var(--ink);font-family:var(--f-mono);font-size:12px;width:80px;text-align:right;padding:2px 4px;outline:none;transition:background .12s;}
.num-input:hover{background:var(--surf2);}
.num-input:focus{background:var(--surf2);outline:1px solid var(--blu);}
.sales-notes-area{width:100%;background:var(--surf2);border:1px solid var(--bdr);border-radius:8px;color:var(--ink2);font-family:var(--f-body);font-size:11px;padding:9px 11px;resize:none;outline:none;min-height:72px;line-height:1.5;}
.sales-notes-area:focus{border-color:var(--bdr2);}

/* CALENDAR */
.cal-layout{padding:20px 24px;overflow-y:auto;}
.cal-topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:12px;}
.cal-title-group{}
.cal-title{font-family:var(--f-display);font-size:28px;letter-spacing:.3px;line-height:1;}
.cal-sub{font-size:12px;color:var(--ink3);margin-top:3px;}
.cal-controls{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.cal-nav-btn{width:30px;height:30px;border-radius:7px;border:1px solid var(--bdr);background:transparent;color:var(--ink2);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s;flex-shrink:0;}
.cal-nav-btn:hover{background:var(--surf2);color:var(--ink);}
.cal-range-label{font-family:var(--f-display);font-size:16px;letter-spacing:.5px;min-width:200px;text-align:center;}
.cal-today-btn{padding:5px 13px;border-radius:7px;border:1px solid var(--bdr);background:transparent;color:var(--ink3);font-family:var(--f-body);font-size:11px;font-weight:600;cursor:pointer;transition:all .12s;}
.cal-today-btn:hover{background:var(--surf2);color:var(--ink);}
.cal-add-btn{padding:5px 13px;border-radius:7px;border:1px dashed var(--bdr2);background:transparent;color:var(--ink4);font-family:var(--f-body);font-size:11px;font-weight:500;cursor:pointer;transition:all .12s;}
.cal-add-btn:hover{border-color:var(--blu);color:var(--blu);background:var(--blu-b);}
.cal-legend{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;padding:10px 14px;background:var(--surf1);border:1px solid var(--bdr0);border-radius:8px;}
.cal-leg-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--ink3);}
.cal-leg-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0;}
.cal-three-wrap{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px;}
.cal-mini-month{background:var(--surf1);border:1px solid var(--bdr0);border-radius:10px;overflow:hidden;transition:border-color .15s;}
.cal-mini-month:hover{border-color:var(--bdr2);}
.cmm-head{display:flex;align-items:center;justify-content:space-between;padding:10px 12px 8px;border-bottom:1px solid var(--bdr0);cursor:pointer;}
.cmm-head:hover{background:var(--surf2);}
.cmm-name{font-family:var(--f-display);font-size:15px;letter-spacing:.5px;}
.cmm-expand-hint{font-size:10px;color:var(--ink4);}
.cmm-days-header{display:grid;grid-template-columns:repeat(7,1fr);padding:5px 6px 3px;}
.cmm-dh{font-size:9px;font-weight:600;letter-spacing:.3px;text-transform:uppercase;color:var(--ink4);text-align:center;}
.cmm-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;padding:3px 4px 6px;}
.cmm-cell{aspect-ratio:1;border-radius:3px;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;cursor:pointer;padding:1px;transition:background .1s;position:relative;min-width:0;}
.cmm-cell:hover{background:var(--surf3);}
.cmm-cell.today{background:var(--surf3);}
.cmm-cell.today .cmm-num{background:var(--blu);color:#fff;border-radius:50%;width:14px;height:14px;display:flex;align-items:center;justify-content:center;font-weight:600;}
.cmm-cell.other{opacity:.25;}
.cmm-cell.selected{background:var(--surf2);box-shadow:inset 0 0 0 1.5px var(--blu);}
.cmm-num{font-size:9px;color:var(--ink3);line-height:1.2;text-align:center;}
.cmm-dots{display:flex;flex-wrap:wrap;gap:1px;justify-content:center;margin-top:1px;max-width:100%;}
.cmm-dot{width:4px;height:4px;border-radius:1px;flex-shrink:0;}
.cal-drawer{background:var(--surf1);border:1px solid var(--bdr0);border-radius:10px;overflow:hidden;margin-bottom:16px;}
.cal-drawer.hidden{display:none;}
.cal-drawer-head{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--bdr0);background:var(--surf0);}
.cdh-date{font-family:var(--f-display);font-size:18px;letter-spacing:.3px;}
.cdh-count{font-size:11px;color:var(--ink3);}
.cdh-close{background:none;border:none;cursor:pointer;color:var(--ink3);font-size:16px;padding:0 4px;border-radius:4px;transition:all .12s;}
.cdh-close:hover{color:var(--ink);background:var(--surf2);}
.cal-drawer-body{padding:10px 0;}
.cdb-event{display:grid;grid-template-columns:3px 1fr;gap:0;padding:10px 16px;border-bottom:1px solid var(--bdr0);transition:background .1s;cursor:default;}
.cdb-event:last-child{border-bottom:none;}
.cdb-event:hover{background:var(--surf2);}
.cdb-stripe{border-radius:2px;margin-right:12px;}
.cdb-content{padding-left:12px;}
.cdb-title{font-size:13px;font-weight:500;color:var(--ink);margin-bottom:5px;line-height:1.3;}
.cdb-title.done-title{color:var(--ink4);text-decoration:line-through;}
.cdb-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.cdb-dept{font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;padding:2px 7px;border-radius:5px;}
.cdb-owner{font-size:11px;color:var(--ink3);}
.cdb-owner span{color:var(--ink2);font-weight:500;}
.cdb-notes{font-size:11px;color:var(--ink3);margin-top:4px;font-style:italic;}
.cdb-empty{padding:20px;font-size:12px;color:var(--ink4);text-align:center;font-style:italic;}
.cal-expanded{display:none;}
.cal-expanded.open{display:block;}
.cal-exp-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.cal-exp-name{font-family:var(--f-display);font-size:22px;letter-spacing:.3px;}
.cal-exp-close{background:none;border:none;cursor:pointer;color:var(--ink3);font-size:12px;font-weight:600;padding:5px 12px;border:1px solid var(--bdr);border-radius:7px;font-family:var(--f-body);transition:all .12s;}
.cal-exp-close:hover{color:var(--ink);border-color:var(--bdr2);}
.cal-exp-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--bdr0);border:1px solid var(--bdr0);border-radius:10px;overflow:hidden;margin-bottom:12px;}
.cal-exp-dh{background:var(--surf0);padding:7px;font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--ink4);text-align:center;}
.cal-exp-day{background:var(--surf1);min-height:82px;padding:6px;cursor:pointer;transition:background .1s;position:relative;}
.cal-exp-day:hover{background:var(--surf2);}
.cal-exp-day.other-month{background:var(--surf0);opacity:.4;}
.cal-exp-day.today-exp{background:var(--surf2);}
.cal-exp-day.selected-day{background:var(--surf2);box-shadow:inset 0 0 0 1.5px var(--blu);}
.cal-exp-num{font-size:11px;color:var(--ink3);margin-bottom:4px;}
.cal-exp-num.today-num{background:var(--blu);color:#fff;border-radius:50%;width:18px;height:18px;display:inline-flex;align-items:center;justify-content:center;font-weight:600;}
.cal-exp-ev{font-size:9px;font-weight:600;padding:2px 5px;border-radius:3px;margin-bottom:2px;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;}
.cal-exp-ev:hover{opacity:.75;}
.cal-exp-more{font-size:9px;color:var(--ink4);padding:0 3px;}
.ev-marketing{background:rgba(240,61,90,.14);color:#f03d5a;}
.ev-sales{background:rgba(40,216,128,.14);color:#28d880;}
.ev-product{background:rgba(80,144,255,.14);color:#5090ff;}
.ev-dtc{background:rgba(240,120,50,.14);color:#f07832;}
.ev-logistics{background:rgba(224,168,48,.14);color:#e0a830;}
.ev-cx{background:rgba(64,212,220,.14);color:#40d4dc;}
.ev-launch{background:rgba(240,61,90,.85);color:#fff;}
.ev-retailer{background:rgba(139,92,246,.14);color:#8b5cf6;}
.ev-manual{background:rgba(64,212,220,.1);color:#40d4dc;}
.cal-upcoming-strip{background:var(--surf1);border:1px solid var(--bdr0);border-radius:10px;padding:14px;}
.cus-title{font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--ink4);margin-bottom:10px;}
.cus-row{display:grid;grid-template-columns:60px 1fr 90px 80px;gap:8px;align-items:center;padding:8px 0;border-bottom:1px solid var(--bdr0);font-size:12px;}
.cus-row:last-child{border-bottom:none;}
.cus-row.header{font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--ink4);padding-bottom:7px;}
.cus-date{font-family:var(--f-mono);font-size:10px;}
.cus-name{color:var(--ink2);line-height:1.3;}
.cus-owner{color:var(--ink3);font-size:11px;}
.cus-badge{display:flex;justify-content:flex-end;}

/* VERSION HISTORY */
.vh-entry{display:flex;align-items:flex-start;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--bdr0);gap:12px;}
.vh-entry:last-child{border-bottom:none;}
.vh-left{display:flex;flex-direction:column;gap:3px;flex:1;min-width:0;}
.vh-label{font-size:13px;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.vh-meta{font-size:10px;color:var(--ink3);font-family:var(--f-mono);}
.vh-projects{font-size:10px;color:var(--ink4);margin-top:1px;}
.vh-actions{display:flex;gap:6px;flex-shrink:0;align-items:center;}
.vh-restore{padding:4px 10px;border-radius:6px;border:1px solid var(--blu);background:var(--blu-a);color:var(--blu);font-family:var(--f-body);font-size:11px;font-weight:600;cursor:pointer;transition:all .12s;white-space:nowrap;}
.vh-restore:hover{background:var(--blu);color:#fff;}
.vh-delete{padding:4px 8px;border-radius:6px;border:1px solid var(--bdr);background:transparent;color:var(--ink4);font-family:var(--f-body);font-size:11px;cursor:pointer;transition:all .12s;}
.vh-delete:hover{border-color:var(--red);color:var(--red);}
.vh-current{font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;background:var(--grn-a);color:var(--grn);white-space:nowrap;}
.vh-auto{font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;background:var(--surf3);color:var(--ink3);white-space:nowrap;}
.vh-manual{font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;background:var(--gld-a);color:var(--gld);white-space:nowrap;}
.vh-empty{font-size:12px;color:var(--ink4);text-align:center;padding:24px 0;font-style:italic;}
.save-version-btn{width:100%;padding:10px;background:var(--gld-a);color:var(--gld);border:1px solid rgba(224,168,48,.25);border-radius:8px;font-family:var(--f-body);font-size:13px;font-weight:600;cursor:pointer;transition:all .12s;margin-bottom:10px;}
.save-version-btn:hover{background:var(--gld);color:var(--bg);}
.version-label-input{width:100%;background:var(--surf2);border:1px solid var(--bdr);border-radius:8px;color:var(--ink);font-family:var(--f-body);font-size:12px;padding:8px 11px;outline:none;margin-bottom:8px;}
.version-label-input:focus{border-color:var(--blu);}

/* EMPTY STATES */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:52px 24px;text-align:center;gap:12px;}
.es-icon{font-size:32px;opacity:.25;}
.es-title{font-size:15px;font-weight:600;color:var(--ink2);}
.es-body{font-size:12px;color:var(--ink3);max-width:300px;line-height:1.6;}
.es-action{margin-top:4px;padding:8px 20px;border-radius:8px;background:var(--blu-a);color:var(--blu);border:1px solid rgba(80,144,255,.25);font-family:var(--f-body);font-size:12px;font-weight:600;cursor:pointer;transition:all .12s;}
.es-action:hover{background:var(--blu);color:#fff;}

/* EDITABLE AFFORDANCE HINT */
.editable-hint{font-size:10px;color:var(--ink3);padding:7px 20px 6px;border-bottom:1px solid var(--bdr);border-left:3px solid var(--coffee);display:flex;align-items:center;gap:5px;background:#f8f4ee;font-style:italic;letter-spacing:.2px;}
</style>

</head>
<body>

