    <div class="m-acts">
      <button class="m-cancel" onclick="closeModal('editProjectModal')">Cancel</button>
      <button style="padding:10px 14px;background:transparent;border:1px solid rgba(240,61,90,.35);color:var(--red);border-radius:8px;font-family:var(--f-body);font-size:13px;cursor:pointer;transition:all .12s;"
