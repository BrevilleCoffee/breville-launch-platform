      <div class="ret-sub">${p.model}${p.name!=='TBD'?' · '+p.name:''} · Launch tasks, PDP status & channel links per retailer.</div>
    </div>`;

  tiers.forEach(tier => {
    const retailers = p.retailers.filter(r=>r.tier===tier.key);
    html += `<div class="ret-tier"><div class="ret-tier-lbl">${tier.label}</div><div class="ret-grid">`;
    retailers.forEach(r => {
      const done = r.tasks.filter(t=>t.done).length;
      const total = r.tasks.length;
      const pct = Math.round((done/total)*100);
      html += `
        <div class="rcard">
          <div class="rcard-head">
            <div style="display:flex;align-items:center">
              <div class="rcard-icon" style="background:${r.color}22;color:${r.color}">${r.icon}</div>
              <div>
                <div class="rcard-name">${r.name}</div>
