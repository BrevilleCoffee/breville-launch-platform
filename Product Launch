function updateSampleQty(pId, idx, val) {
  const p = getProject(pId);
  if(p) { p.samples[idx].qty = parseInt(val)||0; save(); }
}

function cycleSampleStatus(pId, idx) {
  const p = getProject(pId);
  if(!p) return;
  const cycle = ['blocked','progress','done'];
  const cur = p.samples[idx].status || 'blocked';
  p.samples[idx].status = cycle[(cycle.indexOf(cur)+1) % cycle.length];
  save();
  renderSamples();
}

function updateSampleField(pId, idx, field, val) {
  const p = getProject(pId);
  if(p) { p.samples[idx][field] = val; save(); }
}

