    <div style="display:inline-flex;gap:24px;background:var(--surf1);border:1px solid var(--bdr0);border-radius:10px;padding:14px 20px;align-items:center;margin-top:4px">
      <div>
        <div style="font-family:var(--f-display);font-size:30px;line-height:1">${totalQty}</div>
        <div style="font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--ink3);margin-top:3px">Total Units</div>
      </div>
      <div>
        <div style="font-family:var(--f-display);font-size:30px;line-height:1;color:var(--grn)">${p.samples.filter(s=>s.status==='done').length}</div>
        <div style="font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--ink3);margin-top:3px">Shipped</div>
      </div>
      <div>
        <div style="font-family:var(--f-display);font-size:30px;line-height:1;color:var(--org)">${p.samples.filter(s=>s.status==='progress').length}</div>
        <div style="font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--ink3);margin-top:3px">In Transit</div>
      </div>
