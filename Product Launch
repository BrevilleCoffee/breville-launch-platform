<!-- Add Project -->
<div class="modal-ov" id="addProjectModal">
  <div class="modal">
    <div class="m-title">New Project</div>
    <div class="mf"><label class="ml">Model Number</label><input class="mi" id="np-model" placeholder="e.g. BES990"></div>
    <div class="mf"><label class="ml">Product Name</label><input class="mi" id="np-name" placeholder="e.g. Oracle Touch"></div>
    <div class="mf"><label class="ml">Category</label>
      <select class="ms" id="np-cat">
        <option value="coffee">Coffee / Espresso</option>
        <option value="cooking">Cooking / Smart Oven</option>
        <option value="foodprep">Food Prep / Blending</option>
        <option value="water">Water</option>
        <option value="digital">Digital / Software</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div class="mf"><label class="ml">Launch Stage</label>
      <div class="stage-toggle-row" id="np-stage-row">
        <button class="stg-btn" onclick="selectNewStage('dev',this)">Development</button>
        <button class="stg-btn" onclick="selectNewStage('comm',this)">Commercial Go</button>
        <button class="stg-btn active" data-selected="gtm" style="background:var(--blu);border-color:var(--blu);color:#fff" onclick="selectNewStage('gtm',this)">GTM / Launch</button>
        <button class="stg-btn" onclick="selectNewStage('live',this)">Live</button>
      </div>
    </div>
    <div class="mf"><label class="ml">Target Launch Date</label><input class="mi" type="date" id="np-date"></div>
    <div class="mf"><label class="ml">MAP (USD)</label><input class="mi" type="number" id="np-map" placeholder="e.g. 2999.95"></div>
    <div class="mf"><label class="ml">Notes</label><textarea class="mta" id="np-notes" placeholder="Key context, launch partners, strategic priorities..."></textarea></div>
    <div class="m-acts">
      <button class="m-cancel" onclick="closeModal('addProjectModal')">Cancel</button>
      <button class="m-save" onclick="saveNewProject()">Create Project</button>
    </div>
  </div>
</div>

<!-- Add Task -->
<div class="modal-ov" id="addTaskModal">
  <div class="modal">
    <div class="m-title">Add Task</div>
    <div class="mf"><label class="ml">Task Name</label><input class="mi" id="nt-name" placeholder="What needs to happen?"></div>
    <div class="mf"><label class="ml">Department</label>
      <select class="ms" id="nt-dept">
        <option value="product">Product</option>
        <option value="marketing">Marketing / GTM</option>
        <option value="sales">Sales</option>
        <option value="dtc">DTC / eComm</option>
        <option value="logistics">Logistics</option>
        <option value="cx">Customer Support</option>
      </select>
    </div>
    <div class="mf"><label class="ml">Owner</label><input class="mi" id="nt-owner" placeholder="Name"></div>
    <div class="mf"><label class="ml">Due Date</label><input class="mi" type="date" id="nt-due"></div>
    <div class="mf"><label class="ml">Status</label>
      <select class="ms" id="nt-status">
        <option value="blocked">Blocked / Not Started</option>
        <option value="progress">In Progress</option>
        <option value="done">Done</option>
        <option value="na">N/A</option>
      </select>
