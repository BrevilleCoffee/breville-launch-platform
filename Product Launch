    <div class="mf"><label class="ml">Notes</label><textarea class="mta" id="nt-notes" placeholder="Context, links, blockers..."></textarea></div>
    <div class="m-acts">
      <button class="m-cancel" onclick="closeModal('addTaskModal')">Cancel</button>
      <button class="m-save" onclick="saveNewTask()">Add Task</button>
    </div>
  </div>
</div>

<!-- Archive / Delete -->
<div class="modal-ov" id="archiveModal">
  <div class="modal">
    <div class="m-title">Manage Projects</div>
    <div id="archiveList" style="margin-bottom:16px;"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:11px;color:var(--ink3);margin-bottom:16px;padding:10px 12px;background:var(--surf2);border-radius:8px;border:1px solid var(--bdr0)">
      <div><strong style="color:var(--org)">Archive → PDF</strong><br>Exports a PDF snapshot then removes from active list. Recoverable via version history.</div>
      <div><strong style="color:var(--red)">Delete</strong><br>Permanently removes the project. A safety version is auto-saved first so you can restore if needed.</div>
    </div>
    <button class="m-cancel" onclick="closeModal('archiveModal')" style="width:100%">Close</button>
  </div>
</div>

<div class="lock-banner" id="lockBanner">🔒 View-Only Mode</div>

<!-- Data Export / Import / Version History -->
<div class="modal-ov" id="dataModal">
  <div class="modal" style="width:540px">
    <div class="m-title">Data & Version History</div>

    <!-- Save version -->
    <div style="margin-bottom:16px">
      <div style="font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--gld);margin-bottom:8px">Save a Version</div>
      <input class="version-label-input" id="versionLabelInput" placeholder="Label this version (optional — e.g. 'Before Ally's edits')">
      <button class="save-version-btn" onclick="doManualSave()">📌 Save Version Now</button>
    </div>

    <!-- Version list -->
    <div style="font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink4);margin-bottom:8px">Version History <span id="versionCount" style="color:var(--ink4);font-weight:400;letter-spacing:0;text-transform:none"></span></div>
    <div id="versionList" style="max-height:260px;overflow-y:auto;margin-bottom:16px"></div>

    <!-- Export / Import -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px">
      <button onclick="exportJSON()" style="padding:8px;background:var(--grn-a);color:var(--grn);border:1px solid rgba(46,204,130,.3);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer">↓ Export JSON</button>
      <button onclick="document.getElementById('importFileInput').click()" style="padding:8px;background:var(--blu-a);color:var(--blu);border:1px solid rgba(74,143,255,.3);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer">↑ Import JSON</button>
    </div>
    <input type="file" id="importFileInput" accept=".json" style="display:none" onchange="importJSON(this)">

    <div id="storageStatus" style="font-size:10px;color:var(--ink4);margin-bottom:14px;font-family:'DM Mono',monospace"></div>

    <button class="m-cancel" onclick="closeModal('dataModal')" style="width:100%">Close</button>
  </div>
</div>
