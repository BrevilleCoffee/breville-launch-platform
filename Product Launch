let _editProjectId = null;
function openEditProject(id) {
  _editProjectId = id;
  const p = getProject(id);
  if (!p) return;
  document.getElementById('ep-model').value = p.model;
  document.getElementById('ep-name').value  = p.name === 'TBD' ? '' : p.name;
  document.getElementById('ep-cat').value   = p.category;
  document.getElementById('ep-date').value  = p.launchDate || '';
  document.getElementById('ep-map').value   = p.map || '';
  document.getElementById('ep-notes').value = p.notes || '';
  // Build stage toggle buttons
  const row = document.getElementById('ep-stage-row');
  row.innerHTML = STAGE_CYCLE.map(s => `
    <button class="stg-btn ${p.stage===s?'active':''}"
      style="${p.stage===s?`background:${stageColor(s)};border-color:${stageColor(s)};`:`border-color:var(--bdr);`}"
      onclick="selectEditStage('${s}',this)">${stageLabel(s)}</button>
  `).join('');
  openModal('editProjectModal');
}

function selectEditStage(stage, btn) {
  document.querySelectorAll('#ep-stage-row .stg-btn').forEach(b => {
    b.className = 'stg-btn';
    b.style.background = '';
    b.style.borderColor = 'var(--bdr)';
    b.removeAttribute('data-selected');
  });
  btn.className = 'stg-btn active';
  btn.style.background = stageColor(stage);
  btn.style.borderColor = stageColor(stage);
  btn.setAttribute('data-selected', stage);
}

function saveEditProject() {
  const p = getProject(_editProjectId);
  if (!p) return;
  p.model      = document.getElementById('ep-model').value.trim() || p.model;
  p.name       = document.getElementById('ep-name').value.trim()  || 'TBD';
  p.category   = document.getElementById('ep-cat').value;
  p.launchDate = document.getElementById('ep-date').value || '';
  p.map        = parseFloat(document.getElementById('ep-map').value) || 0;
  p.notes      = document.getElementById('ep-notes').value || '';
  const activeBtn = document.querySelector('#ep-stage-row .stg-btn[data-selected]');
  if (activeBtn) p.stage = activeBtn.getAttribute('data-selected');
  save();
  closeModal('editProjectModal');
  renderAll();
  if (state.activeView === 'tracker') renderTracker();
}

