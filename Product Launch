// ═══════════════════════════════════════════
//  SPRINT VIEW
// ═══════════════════════════════════════════
function toggleSprintMode() {
  state.sprintMode = !state.sprintMode;
  if (state.sprintMode) {
    // Default: first two projects
    state.sprintProjects = [
      state.projects[0]?.id || null,
      state.projects[1]?.id || null,
    ];
    state.activeView = 'sprint';
  } else {
    state.activeView = state.activeProjectId ? 'tracker' : 'home';
  }
  save();
  renderAll();
  showView(state.sprintMode ? 'sprint' : state.activeView);
}

function renderSprint() {
  // Guard: auto-assign if not set
  if (!state.sprintProjects[0] && state.projects[0]) state.sprintProjects[0] = state.projects[0].id;
  if (!state.sprintProjects[1] && state.projects[1]) state.sprintProjects[1] = state.projects[1].id;

  const options = state.projects.map(p=>
    `<option value="${p.id}">${p.model} · ${p.name==='TBD'?'TBD':p.name}</option>`
  ).join('');

  let html = `
    <div class="sprint-hero">
      <div class="sprint-title">⚡ Sprint View</div>
      <div class="sprint-sub">This week's in-progress tasks across two products. Quick sync, clear picture.</div>
    </div>
    <div class="sprint-selectors">
      <div class="sprint-sel">
        <label>Project A</label>
        <select id="sprint-sel-0" onchange="updateSprintProject(0,this.value)">${options}</select>
      </div>
      <div class="sprint-sel">
        <label>Project B</label>
        <select id="sprint-sel-1" onchange="updateSprintProject(1,this.value)">${options}</select>
      </div>
    </div>
    <div class="sprint-grid">`;

  [0,1].forEach(col => {
    const pid = state.sprintProjects[col];
    const p = getProject(pid);
    if (!p) {
      html += `<div class="sprint-col"><div class="sprint-empty">Select a project above</div></div>`;
      return;
    }
    const s = getStats(p.tasks);
    const inProg  = p.tasks.filter(t=>t.status==='progress');
    const blocked = p.tasks.filter(t=>t.status==='blocked').slice(0,5);
    const cc = catColor(p.category);

    html += `
      <div class="sprint-col">
        <div class="sprint-col-head">
          <div>
            <div class="sch-model" style="color:${cc}">${p.model}</div>
            <div class="sch-name">${p.name==='TBD'?p.model+' (TBD)':p.name}</div>
          </div>
          <div class="sch-pct" style="color:${pctColor(s.pct)}">${s.pct}%</div>
        </div>
        <div class="sprint-body">`;

    const depts = [...new Set(inProg.map(t=>t.dept))];
    if (inProg.length === 0) {
      html += `<div class="sprint-empty">No in-progress tasks right now</div>`;
    } else {
      depts.forEach(dept => {
        const dt = inProg.filter(t=>t.dept===dept);
        const dc = DEPT_CFG[dept];
        html += `<div class="sprint-dept-section">
          <div class="sds-lbl" style="color:${dc.color}">${dc.label}</div>`;
        dt.forEach(t => {
          html += `<div class="sprint-task">
            <span class="st-bullet" style="background:var(--org)"></span>
            <span class="st-text">${escHtml(t.name)}</span>
            <span class="st-owner">${escHtml(t.owner||'')}</span>
          </div>`;
        });
        html += `</div>`;
      });
    }

    if (blocked.length > 0) {
      html += `<div class="sprint-dept-section" style="margin-top:12px">
        <div class="sds-lbl" style="color:var(--red)">🔴 Blocked</div>`;
      blocked.forEach(t => {
        html += `<div class="sprint-task">
          <span class="st-bullet" style="background:var(--red)"></span>
          <span class="st-text" style="color:var(--ink3)">${escHtml(t.name)}</span>
          <span class="st-owner" style="color:var(--ink3)">${escHtml(t.owner||'')}</span>
        </div>`;
      });
      html += `</div>`;
    }

    // Sales Pulse — the "sales is in the room" numbers
    if (p.sales) {
      const sd = p.sales;
      const sc = sd.scenario || 'likely';
      const isL = sc === 'likely';
      const fcst12 = isL ? sd.fcst12m_l : sd.fcst12m_h;
      const fcst4  = isL ? sd.fcst4m_l  : sd.fcst4m_h;
