// ═══════════════════════════════════════════
function getProject(id) { return state.projects.find(p=>p.id===id); }
function activeProject() { return getProject(state.activeProjectId); }

function getStats(tasks) {
  const active = tasks.filter(t=>t.status!=='na');
  const done = tasks.filter(t=>t.status==='done').length;
  const prog = tasks.filter(t=>t.status==='progress').length;
  const blk  = tasks.filter(t=>t.status==='blocked').length;
  const na   = tasks.filter(t=>t.status==='na').length;
  const pct  = active.length ? Math.round((done/active.length)*100) : 0;
  return { total:tasks.length, done, prog, blk, na, pct };
}

function pctColor(p) {
  if(p>=80) return 'var(--grn)';
  if(p>=50) return 'var(--org)';
  return 'var(--red)';
}

function formatDate(d) {
  if(!d) return '';
  const dt = new Date(d);
  const today = new Date();
  const diff = Math.ceil((dt-today)/(1000*60*60*24));
  const fmt = dt.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  return { fmt, late: diff<0, soon: diff>=0&&diff<=7 };
}

function daysToLaunch(d) {
  if(!d) return null;
  return Math.ceil((new Date(d)-new Date())/(1000*60*60*24));
}

function catColor(cat) { return CAT_CFG[cat]?.color || '#6a6a7a'; }
function stageLabel(s)  { return STAGE_CFG[s]?.label || s; }
function stageBg(s)     { return STAGE_CFG[s]?.bg || 'rgba(106,106,122,.15)'; }
function stageColor(s)  { return STAGE_CFG[s]?.color || '#6a6a7a'; }
function escHtml(s)     { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

