// ═══════════════════════════════════════════
//  PERSISTENCE
// ═══════════════════════════════════════════
function save() {
  // Always write to localStorage as instant local fallback
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e){}
  // Write to Supabase if connected
  if (_sb && _sbConnected) {
    _sb.from('app_state')
      .update({ data: state, updated_at: new Date().toISOString() })
      .eq('id', 'singleton')
      .then(({ error }) => {
        if (error) console.warn('Supabase save error:', error.message);
      });
  }
}
async function load() {
  if (_sb) {
    try {
      const { data, error } = await _sb.from('app_state').select('data').eq('id','singleton').single();
      if (!error && data?.data && Object.keys(data.data).length > 0) {
        Object.assign(state, data.data);
        _sbConnected = true;
        showConnectionStatus('live');
      } else {
        _loadFromLocalStorage();
        _sbConnected = true;
        showConnectionStatus('live');
      }
    } catch(e) {
      console.warn('Supabase load failed, using localStorage:', e);
      _loadFromLocalStorage();
      showConnectionStatus('offline');
    }
  } else {
    _loadFromLocalStorage();
    showConnectionStatus('offline');
  }
  _lastAutoHash = quickHash(state);
}

function _loadFromLocalStorage() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) { const s = JSON.parse(raw); Object.assign(state, s); }
  } catch(e){}
}

function _dedupeProjects() {
  const seen = new Set();
  state.projects = (state.projects||[]).filter(p => {
    if (seen.has(p.id)) return false;
    seen.add(p.id); return true;
  });
}

function quickHash(obj) {
  const s = JSON.stringify((obj.projects||[]).map(p=>({
    id:p.id,
    done:(p.tasks||[]).filter(t=>t.status==='done').length,
    prog:(p.tasks||[]).filter(t=>t.status==='progress').length,
  })));
  let h = 0;
  for (let i=0;i<s.length;i++){ h=((h<<5)-h)+s.charCodeAt(i); h|=0; }
  return h.toString(36);
}

// ── VERSION HISTORY ──
function getHistory() {
  try { return JSON.parse(localStorage.getItem(HISTORY_KEY)||'[]'); } catch(e){ return []; }
}
function putHistory(hist) {
  try { localStorage.setItem(HISTORY_KEY, JSON.stringify(hist)); } catch(e){}
}

function saveVersion(label, type) {
  const hist = getHistory();
  hist.unshift({
    id:   'v_'+Date.now(),
    label: label || formatVersionLabel(),
    type:  type || 'manual',
    ts:    Date.now(),
    projects: state.projects.length,
    names:    state.projects.map(p=>p.model).join(', '),
    snapshot: JSON.parse(JSON.stringify(state)),
  });
  while (hist.length > MAX_VERSIONS) hist.pop();
  putHistory(hist);
}

function formatVersionLabel() {
  return new Date().toLocaleString('en-US',{month:'short',day:'numeric',hour:'numeric',minute:'2-digit',hour12:true});
}

function restoreVersion(id) {
  if (!confirm('Restore this version? Your current state will be saved as a version first so you can undo.')) return;
  saveVersion('Before restore — '+formatVersionLabel(), 'auto');
  const hist = getHistory();
  const entry = hist.find(h=>h.id===id);
  if (!entry) return;
  Object.assign(state, JSON.parse(JSON.stringify(entry.snapshot)));
  save();
  closeModal('dataModal');
  renderAll();
  showView(state.activeView||'home');
}

function deleteVersion(id) {
  if (!confirm('Delete this version? This cannot be undone.')) return;
  putHistory(getHistory().filter(h=>h.id!==id));
  openDataModal(); // refresh modal
}

function startAutoSave() {
  setInterval(()=>{
    const h = quickHash(state);
    if (h !== _lastAutoHash) {
      saveVersion('Auto-save — '+formatVersionLabel(), 'auto');
      _lastAutoHash = h;
    }
  }, AUTO_SAVE_MS);
}

function startRealtime() {
  if (!_sb || !_sbConnected) return;
  _realtimeSub = _sb
    .channel('app_state_changes')
    .on('postgres_changes', {
      event: 'UPDATE',
      schema: 'public',
      table: 'app_state',
      filter: 'id=eq.singleton'
    }, (payload) => {
      // Incoming remote change — merge and re-render without triggering save
      if (!payload.new?.data) return;
      _remoteUpdate = true;
      const incoming = payload.new.data;
      // Preserve local UI state (active project/view) but take remote data
      const localUI = {
        activeProjectId: state.activeProjectId,
        activeView: state.activeView,
        sprintMode: state.sprintMode,
        sprintProjects: state.sprintProjects,
      };
      Object.assign(state, incoming, localUI);
      _dedupeProjects();
      _lastAutoHash = quickHash(state);
      renderAll();
      showSyncPulse();
      _remoteUpdate = false;
    })
    .subscribe();
}

function showSyncPulse() {
  const el = document.getElementById('syncPulse');
  if (!el) return;
  el.classList.add('pulse');
  setTimeout(()=> el.classList.remove('pulse'), 1200);
}

function showConnectionStatus(status) {
  const el = document.getElementById('connStatus');
  if (!el) return;
  if (status === 'live') {
    el.textContent = '● Live';
    el.style.color = 'rgba(40,210,128,.7)';
  } else {
    el.textContent = '○ Offline';
    el.style.color = 'rgba(255,255,255,.3)';
  }
}


